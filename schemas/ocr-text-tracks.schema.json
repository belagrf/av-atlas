{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://av-atlas.local/schemas/ocr-text-tracks/1.0.0",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "association_policy_version", "maximum_association_gap_ms", "tracks"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "association_policy_version": {"const": "ocr-temporal-association/1.0.0"},
    "maximum_association_gap_ms": {"type": "integer", "minimum": 0},
    "tracks": {"type": "array", "items": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "track_id", "source_id", "shot_id", "member_observation_ids", "source_frame_evidence_refs", "first_timestamp_ms", "last_timestamp_ms", "raw_text_variants", "normalized_text", "spatial_boxes", "confidence_values", "confidence_aggregation", "mean_confidence", "association_policy_version", "maximum_association_gap_ms"],
      "properties": {
        "schema_version": {"const": "1.0.0"}, "track_id": {"type": "string"}, "source_id": {"type": "string"}, "shot_id": {"type": "string"},
        "member_observation_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "source_frame_evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "first_timestamp_ms": {"type": "integer", "minimum": 0}, "last_timestamp_ms": {"type": "integer", "minimum": 0},
        "raw_text_variants": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "normalized_text": {"type": "string"}, "spatial_boxes": {"type": "array", "minItems": 1, "items": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "integer"}}},
        "confidence_values": {"type": "array", "minItems": 1, "items": {"type": "number"}}, "confidence_aggregation": {"const": "arithmetic_mean"},
        "mean_confidence": {"type": "number"}, "association_policy_version": {"const": "ocr-temporal-association/1.0.0"},
        "maximum_association_gap_ms": {"type": "integer", "minimum": 0}
      }
    }}
  }
}
