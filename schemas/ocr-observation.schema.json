{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://av-atlas.local/schemas/ocr-observation/1.0.0",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "observation_id", "source_id", "shot_id", "keyframe_id", "timestamp_ms", "text", "normalized_text", "bounding_box", "confidence", "language", "engine", "engine_version", "language_data_identity", "preprocessing", "source_frame_evidence_ref", "adapter_state", "warnings", "evidence_ref"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "observation_id": {"type": "string", "pattern": "^OCR_[0-9]{4}_[0-9]{4}$"},
    "source_id": {"type": "string"}, "shot_id": {"type": "string"}, "keyframe_id": {"type": "string"},
    "timestamp_ms": {"type": "integer", "minimum": 0}, "text": {"type": "string"}, "normalized_text": {"type": "string"},
    "bounding_box": {"type": "array", "prefixItems": [{"type":"integer"},{"type":"integer"},{"type":"integer"},{"type":"integer"}], "minItems":4, "maxItems":4},
    "confidence": {"type":"number","minimum":0,"maximum":100}, "language":{"type":"string"}, "engine":{"const":"tesseract"},
    "engine_version":{"type":"string"}, "language_data_identity":{"type":"string"}, "preprocessing":{"type":"object"},
    "source_frame_evidence_ref":{"type":"string","pattern":"^VID:"}, "adapter_state":{"enum":["disabled","unavailable","skipped","succeeded","partial","failed"]},
    "warnings":{"type":"array","items":{"type":"string"}}, "evidence_ref":{"type":"string","pattern":"^OCR:"}
  }
}
