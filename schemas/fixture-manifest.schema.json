{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://av-atlas.local/schemas/fixture-manifest/1.1.0",
  "$defs": {
    "common": {
      "type": "object",
      "properties": {
        "fixture_id": {"type": "string", "minLength": 1},
        "profile": {"enum": ["m1", "m2a", "m2b", "no-subtitles", "no-video"]},
        "generator_version": {"type": "string", "minLength": 1},
        "source_id": {"type": "string", "pattern": "^SRC_[A-F0-9]{12}$"},
        "content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "ffmpeg_version": {"type": "string", "minLength": 1},
        "parameters": {"type": "object"}
      },
      "required": ["fixture_id", "profile", "generator_version", "source_id", "content_sha256", "ffmpeg_version", "parameters"]
    },
    "sidecar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basename", "type", "payload_schema_version", "sha256", "size_bytes"],
      "properties": {
        "basename": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,254}$"},
        "type": {"const": "observation_sidecar"},
        "payload_schema_version": {"const": "1.0.0"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "size_bytes": {"type": "integer", "minimum": 1, "maximum": 1000000}
      }
    }
  },
  "oneOf": [
    {
      "allOf": [
        {"$ref": "#/$defs/common"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema_version", "fixture_id", "profile", "generator_version", "source_id", "content_sha256", "ffmpeg_version", "parameters"],
          "properties": {
            "schema_version": {"const": "1.0.0"},
            "fixture_id": true, "profile": true, "generator_version": true,
            "source_id": true, "content_sha256": true, "ffmpeg_version": true,
            "parameters": true
          }
        }
      ]
    },
    {
      "allOf": [
        {"$ref": "#/$defs/common"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema_version", "contract_version", "fixture_id", "profile", "generator_version", "source_id", "content_sha256", "ffmpeg_version", "parameters", "sidecars", "manifest_hash"],
          "properties": {
            "schema_version": {"const": "1.1.0"},
            "contract_version": {"const": "av-atlas-controlled-fixture/1.1.0"},
            "fixture_id": true, "profile": true, "generator_version": true,
            "source_id": true, "content_sha256": true, "ffmpeg_version": true,
            "parameters": true,
            "sidecars": {"type": "array", "maxItems": 1, "items": {"$ref": "#/$defs/sidecar"}},
            "manifest_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          }
        }
      ]
    }
  ]
}
