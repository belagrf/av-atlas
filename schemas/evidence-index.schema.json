{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://av-atlas.local/schemas/evidence-index/1.0.0",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "evidence"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "evidence": {"type": "object", "additionalProperties": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence_ref", "source_id", "observation_id", "modality", "start_ms", "end_ms"],
      "properties": {
        "evidence_ref": {"type": "string", "minLength": 1},
        "source_id": {"type": "string"}, "observation_id": {"type": "string"},
        "modality": {"enum": ["VID", "AUD", "ASR", "SUB", "OCR", "ENTITY"]},
        "start_ms": {"type": "integer", "minimum": 0}, "end_ms": {"type": "integer", "minimum": 1}
      }
    }}
  }
}
