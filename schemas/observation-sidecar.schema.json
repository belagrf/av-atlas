{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://av-atlas.local/schemas/observation-sidecar/1.0.0",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "fixture_notice", "observations"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "fixture_notice": {"type": "string", "minLength": 1},
    "observations": {"type": "array", "minItems": 1, "items": {
      "type": "object", "additionalProperties": false,
      "required": ["observation_id", "adapter", "start_ms", "end_ms", "claim_type", "text", "confidence", "modality"],
      "properties": {
        "observation_id": {"type": "string", "minLength": 1},
        "adapter": {"enum": ["visual", "ocr", "asr", "speaker", "acoustic"]},
        "start_ms": {"type": "integer", "minimum": 0},
        "end_ms": {"type": "integer", "minimum": 1},
        "claim_type": {"type": "string", "minLength": 1},
        "text": {"type": "string", "minLength": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "modality": {"enum": ["VID", "AUD", "ASR", "OCR", "ENTITY"]},
        "speaker_id": {"type": "string", "minLength": 1},
        "speech_text": {"type": "string", "minLength": 1}
      }
    }}
  }
}
