{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://av-atlas.local/schemas/config/1.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "chunk_duration_ms", "chunk_overlap_ms", "sample_interval_ms", "adapters"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "chunk_duration_ms": {"type": "integer", "minimum": 1},
    "chunk_overlap_ms": {"type": "integer", "minimum": 0},
    "sample_interval_ms": {"type": "integer", "minimum": 1},
    "adapters": {"type": "array", "uniqueItems": true, "items": {"enum": ["visual", "ocr", "asr", "speaker", "acoustic", "subtitle", "shot", "ocr_frame"]}},
    "subtitle": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "mode": {"enum": ["disabled", "all", "selected"]},
        "tracks": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 0}}
      }
    },
    "shot": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"}, "sample_fps": {"type": "integer", "minimum": 1},
        "hard_threshold": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "gradual_threshold": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "min_duration_ms": {"type": "integer", "minimum": 1},
        "max_duration_ms": {"type": "integer", "minimum": 1},
        "flash_suppression_ms": {"type": "integer", "minimum": 0}
      }
    },
    "resources": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "subprocess_timeout_seconds": {"type": "integer", "minimum": 1},
        "max_duration_ms": {"type": "integer", "minimum": 1},
        "max_video_width": {"type": "integer", "minimum": 1},
        "max_video_height": {"type": "integer", "minimum": 1},
        "max_keyframes": {"type": "integer", "minimum": 1}
      }
    },
    "ocr": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"}, "executable": {"type": "string", "minLength": 1},
        "languages": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z]+$"}},
        "page_segmentation_mode": {"type": "integer", "minimum": 0, "maximum": 13},
        "engine_mode": {"type": "integer", "minimum": 0, "maximum": 3},
        "preprocessing": {
          "type": "object", "additionalProperties": false,
          "properties": {
            "grayscale": {"type": "boolean"}, "contrast_normalization": {"type": "boolean"},
            "threshold": {"type": ["integer", "null"], "minimum": 0, "maximum": 255}
          }
        },
        "minimum_confidence": {"type": "number", "minimum": 0, "maximum": 100},
        "max_frame_dimension": {"type": "integer", "minimum": 1},
        "timeout_seconds": {"type": "integer", "minimum": 1},
        "workers": {"type": "integer", "minimum": 1, "maximum": 4},
        "maximum_frames_per_source": {"type": "integer", "minimum": 1},
        "unavailable_behavior": {"enum": ["degrade", "fail"]},
        "retain_raw_frames": {"const": false},
        "temporal_association_max_gap_ms": {"type": "integer", "minimum": 0, "maximum": 60000}
      }
    }
  }
}
