{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://av-atlas.local/schemas/shot/1.0.0",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "shot_id", "source_id", "start_ms", "end_ms", "boundary_type", "boundary_confidence", "keyframe_id", "evidence_ref"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "shot_id": {"type": "string", "pattern": "^SHOT_[0-9]{4}$"},
    "source_id": {"type": "string"}, "start_ms": {"type": "integer", "minimum": 0},
    "end_ms": {"type": "integer", "minimum": 1},
    "boundary_type": {"enum": ["source_start", "hard_cut", "gradual_transition", "uncertain"]},
    "boundary_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "keyframe_id": {"type": "string", "pattern": "^KEY_[0-9]{4}$"},
    "evidence_ref": {"type": "string", "pattern": "^VID:"}
  }
}
